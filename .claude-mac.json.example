{
  "mcpServers": {
    "google-calendar": {
      "command": "npx",
      "args": ["-y", "@xalia/google-calendar-mcp"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "<YOUR_ABSOLUTE_PATH_TO_BRAIN>/gcp-oauth.keys.json"
      }
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "@piotr-agier/google-drive-mcp"],
      "env": {
        "GOOGLE_DRIVE_OAUTH_CREDENTIALS": "<YOUR_ABSOLUTE_PATH_TO_BRAIN>/gcp-oauth.keys.json"
      }
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y", 
        "@modelcontextprotocol/server-filesystem", 
        "<YOUR_ABSOLUTE_PATH_TO_BRAIN>"
      ]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "<YOUR_BRAVE_API_KEY_HERE>"
      }
    }
  }
}